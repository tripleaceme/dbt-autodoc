# =============================================================================
# dbt-autodoc Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# PROVIDER OPTIONS:
#   anthropic        - Claude models (requires anthropic SDK)
#   openai           - OpenAI models (requires openai SDK)
#   openai_compatible - Any OpenAI-compatible API (DeepSeek, Perplexity, Groq,
#                       Together, Ollama, etc.)
#
# =============================================================================

DBT_AUTODOC_PROVIDER=anthropic
DBT_AUTODOC_API_KEY=your-api-key-here
DBT_AUTODOC_MODEL=claude-sonnet-4-6

# Only required for openai_compatible provider:
# DBT_AUTODOC_BASE_URL=https://api.deepseek.com/v1

# =============================================================================
# Provider-specific model suggestions (uncomment the one you're using):
# =============================================================================
#
# --- Anthropic (Claude) ---
# Docs: https://docs.anthropic.com/en/docs/about-claude/models
# DBT_AUTODOC_MODEL=claude-sonnet-4-6        # Best balance of speed & quality
# DBT_AUTODOC_MODEL=claude-opus-4-6          # Highest quality, slower
# DBT_AUTODOC_MODEL=claude-haiku-4-5-20251001       # Fastest, cheapest
#
# --- OpenAI ---
# Docs: https://platform.openai.com/docs/models
# DBT_AUTODOC_MODEL=gpt-4o                  # Best balance
# DBT_AUTODOC_MODEL=gpt-4o-mini             # Faster, cheaper
# DBT_AUTODOC_MODEL=o3-mini                  # Reasoning model
#
# --- DeepSeek (openai_compatible) ---
# Docs: https://platform.deepseek.com/api-docs
# DBT_AUTODOC_BASE_URL=https://api.deepseek.com/v1
# DBT_AUTODOC_MODEL=deepseek-chat
#
# --- Perplexity (openai_compatible) ---
# Docs: https://docs.perplexity.ai/guides/model-cards
# DBT_AUTODOC_BASE_URL=https://api.perplexity.ai
# DBT_AUTODOC_MODEL=sonar-pro
#
# --- Groq (openai_compatible) ---
# Docs: https://console.groq.com/docs/models
# DBT_AUTODOC_BASE_URL=https://api.groq.com/openai/v1
# DBT_AUTODOC_MODEL=llama-3.3-70b-versatile
#
# --- Google Gemini (openai_compatible) ---
# Docs: https://ai.google.dev/gemini-api/docs/models
# DBT_AUTODOC_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# DBT_AUTODOC_MODEL=gemini-2.0-flash
#
# --- Ollama / Local (openai_compatible) ---
# Docs: https://ollama.com/library
# DBT_AUTODOC_BASE_URL=http://localhost:11434/v1
# DBT_AUTODOC_MODEL=llama3
# DBT_AUTODOC_API_KEY=ollama               # Ollama ignores this but it must be set
